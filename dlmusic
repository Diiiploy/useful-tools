#!/usr/bin/env python3
"""dlmusic — Download YouTube (or any yt-dlp-supported) audio to ~/Music.

Files land slug-cased: "Chopin - Greatest Hits (2hr Mix)" -> chopin-greatest-hits-2hr-mix.opus

Usage:
  dlmusic                # read URL from X11 clipboard (xclip)
  dlmusic <URL>          # use the given URL
  dlmusic -s [URL]       # split by YouTube chapters into numbered track files
  dlmusic --split [URL]  # same as -s
  dlmusic -h | --help    # this help

Features:
  - Auto-slugifies title (unicode -> ASCII transliteration; "Café" -> "cafe")
  - Best audio, no re-encode (`yt-dlp -f ba -x`)
  - Embeds YouTube thumbnail as cover art
  - Embeds metadata (title, uploader, etc.)
  - Skips download if a matching file already exists in ~/Music (dedupe)
  - Sends a desktop notification on done / skip / fail (`notify-send`)
  - --split: each chapter becomes its own file
      e.g. chopin-greatest-hits-01-nocturne.opus
            chopin-greatest-hits-02-polonaise.opus
            (the full mix file is removed when splitting succeeds)

Exit codes:
  0 = success or dedupe-skip
  2 = bad invocation / missing dependency / no URL
  other = yt-dlp's exit code
"""
from __future__ import annotations

import argparse
import json
import os
import re
import shutil
import subprocess
import sys
import unicodedata
from pathlib import Path

MUSIC_DIR = Path.home() / "Music"
SLUG_MAX = 80
AUDIO_EXTS = {".opus", ".m4a", ".mp3", ".ogg", ".flac", ".wav", ".aac", ".mka", ".webm"}


def slugify(text: str) -> str:
    text = unicodedata.normalize("NFKD", text).encode("ascii", "ignore").decode("ascii")
    s = re.sub(r"[^a-zA-Z0-9]+", "-", text).strip("-").lower()
    s = re.sub(r"-+", "-", s)
    return (s[:SLUG_MAX].rstrip("-")) or "untitled"


def read_clipboard() -> str | None:
    for cmd in (
        ["xclip", "-selection", "clipboard", "-o"],
        ["xsel", "--clipboard", "--output"],
        ["wl-paste"],
    ):
        if shutil.which(cmd[0]):
            try:
                out = subprocess.run(cmd, capture_output=True, text=True, timeout=5)
                if out.returncode == 0:
                    return out.stdout.strip()
            except Exception:
                continue
    return None


def notify(title: str, body: str) -> None:
    if shutil.which("notify-send"):
        subprocess.run(
            ["notify-send", "-a", "dlmusic", "-i", "audio-x-generic", title, body],
            check=False,
        )


def fetch_metadata(url: str) -> dict:
    result = subprocess.run(
        ["yt-dlp", "--dump-single-json", "--no-playlist", "--skip-download", url],
        capture_output=True, text=True, check=True,
    )
    return json.loads(result.stdout)


def existing_files(slug: str, split: bool) -> list[Path]:
    if split:
        return sorted(p for p in MUSIC_DIR.glob(f"{slug}-[0-9][0-9]-*")
                      if p.suffix.lower() in AUDIO_EXTS)
    return sorted(p for p in MUSIC_DIR.glob(f"{slug}.*")
                  if p.suffix.lower() in AUDIO_EXTS)


def cleanup_thumbnail_orphans(slug: str) -> None:
    for ext in (".webp", ".png", ".jpg", ".jpeg"):
        for f in MUSIC_DIR.glob(f"{slug}*{ext}"):
            try:
                f.unlink()
            except OSError:
                pass


def post_process_split(slug: str) -> list[str]:
    renamed: list[str] = []
    full_marker = f"{slug}__FULL__"
    chapter_marker = f"{slug}__CHAPTER__"

    # Delete the full mix file; the user opted into per-chapter splits.
    for f in MUSIC_DIR.glob(f"{full_marker}.*"):
        try:
            f.unlink()
        except OSError:
            pass

    # Rename chapter files: <slug>__CHAPTER__NN__<raw title>.<ext>
    #                    -> <slug>-NN-<slugified title>.<ext>
    for f in sorted(MUSIC_DIR.glob(f"{chapter_marker}*")):
        rest = f.stem[len(chapter_marker):]
        parts = rest.split("__", 1)
        if len(parts) == 2 and parts[0].isdigit():
            num, title_raw = parts
            new_stem = f"{slug}-{num.zfill(2)}-{slugify(title_raw)}"
        else:
            new_stem = f"{slug}-{slugify(rest)}"
        new_path = f.with_name(new_stem + f.suffix)
        if new_path.exists() and new_path != f:
            new_path.unlink()
        f.rename(new_path)
        renamed.append(new_path.name)
    return renamed


def download(url: str, split: bool) -> int:
    MUSIC_DIR.mkdir(parents=True, exist_ok=True)

    print("[dlmusic] Fetching metadata...", file=sys.stderr)
    try:
        meta = fetch_metadata(url)
    except subprocess.CalledProcessError as e:
        sys.stderr.write(e.stderr or "")
        print(f"[dlmusic] yt-dlp metadata fetch failed (exit {e.returncode})", file=sys.stderr)
        notify("dlmusic: failed", "metadata fetch failed")
        return e.returncode or 1

    title = meta.get("title") or "untitled"
    slug = slugify(title)
    chapters = meta.get("chapters") or []

    if split and not chapters:
        print(f"[dlmusic] No chapters in '{title}' — downloading as a single file", file=sys.stderr)
        split = False

    pre_existing = existing_files(slug, split)
    if pre_existing:
        names = ", ".join(f.name for f in pre_existing[:3])
        if len(pre_existing) > 3:
            names += f" (+{len(pre_existing) - 3} more)"
        print(f"[dlmusic] Skipping (already exists): {names}", file=sys.stderr)
        notify("dlmusic: skipped", names + " (already exists)")
        return 0

    print(f"[dlmusic] Title: {title}", file=sys.stderr)
    print(f"[dlmusic] Slug:  {slug}", file=sys.stderr)
    if split:
        print(f"[dlmusic] Chapters: {len(chapters)} — splitting", file=sys.stderr)

    cmd = [
        "yt-dlp",
        "-f", "ba", "-x",
        "--embed-thumbnail",
        "--embed-metadata",
        "--no-playlist",
        "--no-overwrites",
    ]

    if split:
        cmd += [
            "--split-chapters",
            "-o", f"chapter:{MUSIC_DIR}/{slug}__CHAPTER__%(section_number)02d__%(section_title)s.%(ext)s",
            "-o", f"{MUSIC_DIR}/{slug}__FULL__.%(ext)s",
        ]
    else:
        cmd += ["-o", f"{MUSIC_DIR}/{slug}.%(ext)s"]

    cmd.append(url)
    result = subprocess.run(cmd)

    if result.returncode != 0:
        print(f"[dlmusic] yt-dlp failed (exit {result.returncode})", file=sys.stderr)
        cleanup_thumbnail_orphans(slug)
        notify("dlmusic: failed", f"yt-dlp exit {result.returncode}")
        return result.returncode

    # Belt-and-suspenders: drop any stray thumbnail files that yt-dlp didn't clean up.
    cleanup_thumbnail_orphans(slug)

    if split:
        files = post_process_split(slug)
    else:
        files = [p.name for p in existing_files(slug, split=False)]

    names = ", ".join(files[:3])
    if len(files) > 3:
        names += f" (+{len(files) - 3} more)"
    print(f"[dlmusic] Done: {names}", file=sys.stderr)
    notify("dlmusic: done", names or slug)
    return 0


def main() -> int:
    parser = argparse.ArgumentParser(
        prog="dlmusic",
        description="Download YouTube audio to ~/Music with slug-cased filenames.",
    )
    parser.add_argument("url", nargs="?",
                        help="URL (omit to read from clipboard via xclip/wl-paste)")
    parser.add_argument("-s", "--split", action="store_true",
                        help="Split by chapters when available")
    args = parser.parse_args()

    if shutil.which("yt-dlp") is None:
        print("[dlmusic] yt-dlp is not installed (pipx install yt-dlp)", file=sys.stderr)
        return 2

    url = args.url or read_clipboard()
    if not url:
        print("[dlmusic] No URL given and clipboard is empty / no clipboard tool found.",
              file=sys.stderr)
        print("[dlmusic] Usage: dlmusic <URL>  |  dlmusic -s <URL>  |  dlmusic  (uses clipboard)",
              file=sys.stderr)
        return 2

    if not re.match(r"^https?://", url):
        print(f"[dlmusic] Clipboard / arg is not a URL: {url[:120]}", file=sys.stderr)
        return 2

    return download(url, args.split)


if __name__ == "__main__":
    sys.exit(main())
